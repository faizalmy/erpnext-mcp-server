# ERPNext instance URL
ERPNEXT_URL=http://localhost:8080

# Token auth (production) — generate in User > API Access
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# Password auth (development) — used if API key/secret are empty
ERPNEXT_USR=Administrator
ERPNEXT_PWD=admin

# Auto-discovery filters (optional, comma-separated DocType names)
# Only discover these DocTypes (empty = all):
# ERPNEXT_DISCOVERY_INCLUDE=Customer,Supplier,Sales Invoice,Purchase Invoice
# Skip these DocTypes (empty = none):
# ERPNEXT_DISCOVERY_EXCLUDE=Deleted Document,Error Log

# Cache settings (optional)
# ERPNEXT_CACHE_DIR=.cache
# ERPNEXT_CACHE_FILE=doctypes.json
# ERPNEXT_CACHE_TTL=86400  # seconds (24h). 0 = always refresh.

# HTTP transport settings (optional, for --http mode)
# ERPNEXT_HTTP_HOST=127.0.0.1
# ERPNEXT_HTTP_PORT=3000

# API key for HTTP transport auth (empty = no auth, local dev only)
# ERPNEXT_MCP_API_KEY=
