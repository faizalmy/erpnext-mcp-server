# erpnext-mcp-server environment
# Copy to .env and fill in your values: cp .env.example .env

# ERPNext connection
ERPNEXT_URL=http://host.docker.internal:8080
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_USR=Administrator
ERPNEXT_PWD=admin

# HTTP transport auth (empty = no auth)
ERPNEXT_MCP_API_KEY=
